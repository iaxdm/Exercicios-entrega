//Listar todos
GET http://localhost:3000/api/produtos

###
//Listar por id
GET http://localhost:3000/api/produtos/3

###
//Cadastrar

POST http://localhost:3000/api/produtos
Content-Type: application/json

{
    "nome":"Café cuado",
    "preco": "2.50",
    "estoque": 20
}

###
//Atualizar

PATCH http://localhost:3000/api/produtos/3
Content-Type: application/json

{
    "nome": "Café cuado 2"
}

###
//Deletar

DELETE http://localhost:3000/api/produtos/1
